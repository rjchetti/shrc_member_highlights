rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'rjchetti@gmail.com' || 
         request.auth.token.email == 'president@seoulhanmaumrotaryclub.org');
    }

    match /highlights/{monthYear}/{userId}_{fileName} {
      // Write: Only the owner can upload, and only if they are the userId in the path
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Read: The owner or Admins
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}
